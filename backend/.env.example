# Django Settings
SECRET_KEY=django-insecure-replace-this-with-a-secure-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Note: SQLite database path will default to db.sqlite3 in backend/ directory if not specified.
DATABASE_URL=sqlite:///db.sqlite3

# Security & CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT Configuration
JWT_SECRET_KEY=jwt-secret-key-replace-this-for-production
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# Application Info
APP_NAME=BAHub
APP_VERSION=1.0.0
SUPPORT_EMAIL=support@bahub.local

# SMTP Configuration (Mocked for now)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@bahub.local
